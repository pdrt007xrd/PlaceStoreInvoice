@model Ventas.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Acceso";
}

<section class="login-page">
    <div class="login-card">
        <div class="mb-4 text-center">
            <div class="small text-uppercase text-muted">Place Store</div>
            <h1 class="h3 mb-2">Iniciar sesion</h1>
            <p class="text-muted mb-0">Usuario inicial: <strong>admin</strong> / clave: <strong>Admin123*</strong></p>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3 text-center">
                <label asp-for="UserName" class="form-label">Usuario</label>
                <input asp-for="UserName" class="form-control" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="mb-4 text-center">
                <label asp-for="Password" class="form-label">Contraseña</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Entrar al sistema</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
