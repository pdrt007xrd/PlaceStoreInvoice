@model Supplier
@{
    ViewData["Title"] = "Nuevo proveedor";
}
<section class="panel-card">
    <form asp-action="CrearProveedor" method="post">
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label" asp-for="Name"></label><input class="form-control" asp-for="Name" /></div>
            <div class="col-md-6"><label class="form-label" asp-for="TaxId">RNC o Cedula</label><input class="form-control" asp-for="TaxId" /></div>
            <div class="col-md-6"><label class="form-label" asp-for="Address"></label><input class="form-control" asp-for="Address" /></div>
            <div class="col-md-6"><label class="form-label" asp-for="ContactName"></label><input class="form-control" asp-for="ContactName" /></div>
            <div class="col-md-6"><label class="form-label" asp-for="Phone"></label><input class="form-control" asp-for="Phone" /></div>
            <div class="col-md-6"><label class="form-label" asp-for="Email"></label><input class="form-control" asp-for="Email" /></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Guardar</button>
            <a class="btn btn-outline-secondary" asp-action="Proveedores">Volver</a>
        </div>
    </form>
</section>
