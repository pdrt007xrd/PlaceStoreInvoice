@model Customer
@{
    ViewData["Title"] = "Editar cliente";
}
<section class="panel-card">
    <form asp-action="EditarCliente" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="CreatedBy" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label" asp-for="Name"></label><input class="form-control" asp-for="Name" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label class="form-label" asp-for="TaxId">RNC o Cédula</label><input class="form-control" asp-for="TaxId" /><span asp-validation-for="TaxId" class="text-danger"></span></div>
            <div class="col-md-6"><label class="form-label" asp-for="Address"></label><input class="form-control" asp-for="Address" /><span asp-validation-for="Address" class="text-danger"></span></div>
            <div class="col-md-3"><label class="form-label" asp-for="Phone">Teléfono</label><input class="form-control" asp-for="Phone" /><span asp-validation-for="Phone" class="text-danger"></span></div>
            <div class="col-md-3"><label class="form-label" asp-for="PaymentMethod">Forma de pago</label><select class="form-select" asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select><span asp-validation-for="PaymentMethod" class="text-danger"></span></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Guardar cambios</button>
            <a class="btn btn-outline-secondary" asp-action="Clientes">Volver</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
