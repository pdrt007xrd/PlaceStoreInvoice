@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Place Store</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ventas.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="layout-grid">
            <aside class="sidebar">
                <div class="sidebar-mobile-header d-lg-none">
                    <div class="brand-block compact">
                        <div class="brand-badge">PS</div>
                        <div>
                            <strong>Place Store</strong>
                            <div class="small text-white-50">Sistema de ventas</div>
                        </div>
                    </div>
                    <button class="btn sidebar-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-expanded="false" aria-controls="sidebarMenu">
                        Menu
                    </button>
                </div>

                <div class="collapse d-lg-block sidebar-collapse" id="sidebarMenu">
                    <div class="brand-block desktop-brand">
                        <div class="brand-badge">PS</div>
                        <div>
                            <strong>Place Store</strong>
                            <div class="small text-white-50">Sistema de ventas</div>
                        </div>
                    </div>

                    <nav class="menu-group">
                        <a class="menu-item @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Dashboard</a>

                        <div class="menu-title">Maestros</div>
                        <a class="menu-item @(currentAction == "Clientes" ? "active" : "")" asp-controller="Maestros" asp-action="Clientes">Clientes</a>
                        <a class="menu-item @(currentAction == "Proveedores" ? "active" : "")" asp-controller="Maestros" asp-action="Proveedores">Proveedores</a>
                        <a class="menu-item @(currentAction == "ProductosServicios" ? "active" : "")" asp-controller="Maestros" asp-action="ProductosServicios">Productos / Servicios</a>

                        <div class="menu-title">Ventas</div>
                        <a class="menu-item @(currentAction == "Cotizaciones" ? "active" : "")" asp-controller="Ventas" asp-action="Cotizaciones">Cotizaciones</a>
                        <a class="menu-item @(currentAction == "Facturas" ? "active" : "")" asp-controller="Ventas" asp-action="Facturas">Facturas</a>
                        <a class="menu-item @(currentAction == "NotasCredito" ? "active" : "")" asp-controller="Ventas" asp-action="NotasCredito">Notas de credito</a>

                        <div class="menu-title">Compras</div>
                        <a class="menu-item @(currentAction == "RegistroCompras" ? "active" : "")" asp-controller="Compras" asp-action="RegistroCompras">Registro de compras</a>
                        <a class="menu-item @(currentAction == "FacturasProveedor" ? "active" : "")" asp-controller="Compras" asp-action="FacturasProveedor">Facturas de proveedor</a>

                        <div class="menu-title">Tesoreria</div>
                        <a class="menu-item @(currentAction == "Cobros" ? "active" : "")" asp-controller="Tesoreria" asp-action="Cobros">Cobros</a>
                        <a class="menu-item @(currentAction == "PagosProveedores" ? "active" : "")" asp-controller="Tesoreria" asp-action="PagosProveedores">Pagos a proveedores</a>
                        <a class="menu-item @(currentAction == "CajaBancos" ? "active" : "")" asp-controller="Tesoreria" asp-action="CajaBancos">Caja / Bancos</a>

                        <div class="menu-title">Reportes</div>
                        <a class="menu-item @(currentAction == "Ventas" ? "active" : "")" asp-controller="Reportes" asp-action="Ventas">Ventas</a>
                        <a class="menu-item @(currentAction == "Compras" ? "active" : "")" asp-controller="Reportes" asp-action="Compras">Compras</a>
                        <a class="menu-item @(currentAction == "CuentasPorCobrar" ? "active" : "")" asp-controller="Reportes" asp-action="CuentasPorCobrar">Cuentas por cobrar</a>
                        <a class="menu-item @(currentAction == "CuentasPorPagar" ? "active" : "")" asp-controller="Reportes" asp-action="CuentasPorPagar">Cuentas por pagar</a>
                        <a class="menu-item @(currentAction == "NotasCredito" ? "active" : "")" asp-controller="Reportes" asp-action="NotasCredito">Notas de credito</a>
                        <a class="menu-item @(currentAction == "LibroVentas" ? "active" : "")" asp-controller="Reportes" asp-action="LibroVentas">Libro de ventas</a>
                        <a class="menu-item @(currentAction == "LibroCompras" ? "active" : "")" asp-controller="Reportes" asp-action="LibroCompras">Libro de compras</a>
                        <a class="menu-item @(currentAction == "FlujoCaja" ? "active" : "")" asp-controller="Reportes" asp-action="FlujoCaja">Flujo de caja</a>

                        <div class="menu-title">Configuracion</div>
                        <a class="menu-item @(currentAction == "Empresa" ? "active" : "")" asp-controller="Configuracion" asp-action="Empresa">Empresa</a>
                        <a class="menu-item @(currentAction == "UsuariosRoles" ? "active" : "")" asp-controller="Configuracion" asp-action="UsuariosRoles">Usuarios / Roles</a>
                    </nav>
                </div>
            </aside>

            <div class="content-wrap">
                <header class="topbar">
                    <div>
                        <div class="small text-muted">Panel operativo</div>
                        <h1 class="page-title">@ViewData["Title"]</h1>
                    </div>
                    <div class="topbar-actions">
                        <span class="welcome-text">@User.Identity?.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-danger">Salir</button>
                        </form>
                    </div>
                </header>

                <main class="page-content">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    <span>Desarrollado por DevTechRD 829-966-1111</span>
                    <a class="btn btn-success btn-sm footer-whatsapp" href="https://wa.me/18299661111" target="_blank" rel="noopener noreferrer">WhatsApp</a>
                </footer>
            </div>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
        <footer class="app-footer public-footer">
            <span>Desarrollado por DevTechRD 829-966-1111</span>
            <a class="btn btn-success btn-sm footer-whatsapp" href="https://wa.me/18299661111" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.addEventListener("pageshow", function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
