@model Ventas.ViewModels.ReportResultViewModel
<section class="panel-card">
    <div class="mb-4">
        <h2 class="h4 mb-1">@Model.Company.BusinessName</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Company.TaxId))
        {
            <div>RNC/Cedula: @Model.Company.TaxId</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Company.Address))
        {
            <div>Direccion: @Model.Company.Address</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Company.Phone) || !string.IsNullOrWhiteSpace(Model.Company.Email))
        {
            <div>Telefono: @Model.Company.Phone  Correo: @Model.Company.Email</div>
        }
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-3"><label class="form-label">Desde</label><input class="form-control" type="date" name="from" value="@Model.Filters.From?.ToString("yyyy-MM-dd")" /></div>
        <div class="col-md-3"><label class="form-label">Hasta</label><input class="form-control" type="date" name="to" value="@Model.Filters.To?.ToString("yyyy-MM-dd")" /></div>
        @if (ViewBag.Customers is IEnumerable<Customer> customers)
        {
            <div class="col-md-3">
                <label class="form-label">Cliente</label>
                <select class="form-select" name="customerId">
                    <option value="">Todos</option>
                    @foreach (var item in customers)
                    {
                        if (Model.Filters.CustomerId == item.Id)
                        {
                            <option value="@item.Id" selected>@item.Name</option>
                        }
                        else
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>
        }
        @if (ViewBag.Suppliers is IEnumerable<Supplier> suppliers)
        {
            <div class="col-md-3">
                <label class="form-label">Proveedor</label>
                <select class="form-select" name="supplierId">
                    <option value="">Todos</option>
                    @foreach (var item in suppliers)
                    {
                        if (Model.Filters.SupplierId == item.Id)
                        {
                            <option value="@item.Id" selected>@item.Name</option>
                        }
                        else
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>
        }
        @if (ViewBag.EnableStatusFilter == true)
        {
            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select class="form-select" name="status" asp-items="Html.GetEnumSelectList<DocumentStatus>()">
                    <option value="">Todos</option>
                </select>
            </div>
        }
        <div class="col-md-4">
            <label class="form-label">Busqueda</label>
            <input class="form-control" type="text" name="search" value="@Model.Filters.Search" list="searchSuggestions" />
        </div>
        <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100" type="submit">Filtrar</button></div>
    </form>

    @if ((ViewBag.Customers is IEnumerable<Customer>) || (ViewBag.Suppliers is IEnumerable<Supplier>))
    {
        <datalist id="searchSuggestions">
            @if (ViewBag.Customers is IEnumerable<Customer> customerOptions)
            {
                @foreach (var item in customerOptions)
                {
                    <option value="@item.Name"></option>
                }
            }
            @if (ViewBag.Suppliers is IEnumerable<Supplier> supplierOptions)
            {
                @foreach (var item in supplierOptions)
                {
                    <option value="@item.Name"></option>
                }
            }
        </datalist>
    }

    <div class="section-header">
        <h3 class="h5 mb-0">@Model.Title</h3>
        <a class="btn btn-outline-secondary"
           asp-action="ExportPdf"
           asp-route-type="@ViewBag.ReportType"
           asp-route-from="@Model.Filters.From?.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.Filters.To?.ToString("yyyy-MM-dd")"
           asp-route-search="@Model.Filters.Search"
           asp-route-customerId="@Model.Filters.CustomerId"
           asp-route-supplierId="@Model.Filters.SupplierId"
           asp-route-status="@Model.Filters.Status">Generar PDF</a>
    </div>

    <table class="table table-striped datatable">
        <thead><tr><th>Fecha</th><th>Principal</th><th>Detalle</th><th>Estado</th><th>Monto</th></tr></thead>
        <tbody>
        @foreach (var item in Model.Rows)
        {
            <tr><td>@item.Date</td><td>@item.Main</td><td>@item.Secondary</td><td>@item.Status</td><td>@item.Amount.ToString("N2")</td></tr>
        }
        </tbody>
    </table>
</section>
