@model CreditNote
@{
    ViewData["Title"] = "Nueva nota de credito";
    var rows = Model.Items?.Any() == true ? Model.Items.ToList() : new List<CreditNoteItem> { new() { Quantity = 1 } };
}
<section class="panel-card">
    <form asp-action="CrearNotaCredito" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-3"><label class="form-label" asp-for="Number"></label><input class="form-control" asp-for="Number" /></div>
            <div class="col-md-3"><label class="form-label" asp-for="Date"></label><input class="form-control" asp-for="Date" type="date" /></div>
            <div class="col-md-3"><label class="form-label" asp-for="InvoiceId">Factura</label><select class="form-select" asp-for="InvoiceId" asp-items="ViewBag.Invoices"></select></div>
            <div class="col-md-3"><label class="form-label" asp-for="Status">Estado</label><select class="form-select" asp-for="Status" asp-items="Html.GetEnumSelectList<DocumentStatus>()"></select></div>
        </div>
        <hr />
        <datalist id="products-list">
            @foreach (var product in (IEnumerable<ProductService>)ViewBag.ProductsData)
            {
                <option value="@product.Name" data-id="@product.Id" data-price="@product.SalePrice"></option>
            }
        </datalist>
        <div id="creditnote-items" class="item-lines" data-next-index="@rows.Count">
            @for (var i = 0; i < rows.Count; i++)
            {
                var item = rows[i];
                var productName = ((IEnumerable<ProductService>)ViewBag.ProductsData).FirstOrDefault(x => x.Id == item.ProductServiceId)?.Name ?? string.Empty;
                <div class="row g-3 item-row mb-2">
                    <input type="hidden" name="Items[@i].ProductServiceId" id="CreditItems_@(i)__ProductServiceId" value="@item.ProductServiceId" />
                    <div class="col-md-4"><label class="form-label">Producto / Servicio</label><input class="form-control autocomplete-input product-autocomplete" list="products-list" value="@productName" data-hidden-target="CreditItems_@(i)__ProductServiceId" data-price-target="CreditItems_@(i)__UnitPrice" /></div>
                    <div class="col-md-2"><label class="form-label">Cantidad</label><input name="Items[@i].Quantity" class="form-control qty-input" value="@item.Quantity.ToString("0.##")" /></div>
                    <div class="col-md-2"><label class="form-label">Precio</label><input id="CreditItems_@(i)__UnitPrice" name="Items[@i].UnitPrice" class="form-control price-input" value="@item.UnitPrice.ToString("0.##")" /></div>
                    <div class="col-md-2"><label class="form-label">Total</label><input name="Items[@i].Total" class="form-control total-input" value="@item.Total.ToString("0.##")" readonly /></div>
                    <div class="col-md-2 d-flex align-items-end"><button type="button" class="btn btn-outline-danger remove-item-row w-100">Quitar</button></div>
                </div>
            }
        </div>
        <button type="button" class="btn btn-outline-primary add-item-row" data-target="#creditnote-items" data-template="#credit-note-template">Agregar linea</button>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Guardar nota de credito</button>
            <a class="btn btn-outline-secondary" asp-action="NotasCredito">Volver</a>
        </div>
    </form>
</section>

<template id="credit-note-template">
    <div class="row g-3 item-row mb-2">
        <input type="hidden" name="Items[__INDEX__].ProductServiceId" id="CreditItems___INDEX___ProductServiceId" value="" />
        <div class="col-md-4"><label class="form-label">Producto / Servicio</label><input class="form-control autocomplete-input product-autocomplete" list="products-list" value="" data-hidden-target="CreditItems___INDEX___ProductServiceId" data-price-target="CreditItems___INDEX___UnitPrice" /></div>
        <div class="col-md-2"><label class="form-label">Cantidad</label><input name="Items[__INDEX__].Quantity" class="form-control qty-input" value="1" /></div>
        <div class="col-md-2"><label class="form-label">Precio</label><input id="CreditItems___INDEX___UnitPrice" name="Items[__INDEX__].UnitPrice" class="form-control price-input" value="0" /></div>
        <div class="col-md-2"><label class="form-label">Total</label><input name="Items[__INDEX__].Total" class="form-control total-input" value="0" readonly /></div>
        <div class="col-md-2 d-flex align-items-end"><button type="button" class="btn btn-outline-danger remove-item-row w-100">Quitar</button></div>
    </div>
</template>
