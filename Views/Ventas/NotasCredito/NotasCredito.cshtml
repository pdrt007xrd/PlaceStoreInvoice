@model IEnumerable<CreditNote>
@{
    ViewData["Title"] = "Notas de crédito";
}
<section class="panel-card">
    <div class="section-header">
        <h3 class="h5 mb-0">Notas de crédito</h3>
        <a class="btn btn-primary" asp-action="CrearNotaCredito">Nueva nota de crédito</a>
    </div>
    <table class="table table-striped datatable">
        <thead><tr><th>Número</th><th>Fecha</th><th>Factura</th><th>Estado</th><th>Total</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr><td>@item.Number</td><td>@item.Date.ToString("dd/MM/yyyy")</td><td>@item.Invoice?.Number</td><td>@item.Status.GetDisplayName()</td><td>@item.Total.ToString("N2")</td></tr>
        }
        </tbody>
    </table>
</section>
