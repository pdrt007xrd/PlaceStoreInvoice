@model Quote
@{
    ViewData["Title"] = "Nueva cotización";
    var customerName = ((IEnumerable<Customer>)ViewBag.CustomersData).FirstOrDefault(x => x.Id == Model.CustomerId)?.Name ?? string.Empty;
}
<section class="panel-card">
    <form asp-action="CrearCotizacion" method="post">
        <div class="row g-3">
            <div class="col-md-3"><label class="form-label" asp-for="Number"></label><input class="form-control" asp-for="Number" /></div>
            <div class="col-md-3"><label class="form-label" asp-for="Date"></label><input class="form-control" asp-for="Date" type="date" /></div>
            <input type="hidden" asp-for="CustomerId" id="CustomerId" />
            <div class="col-md-3">
                <label class="form-label" asp-for="CustomerId">Cliente</label>
                <input class="form-control autocomplete-input" id="customer-search" list="customers-list" value="@customerName" data-hidden-target="CustomerId" placeholder="Escriba para buscar un cliente" autocomplete="off" />
            </div>
            <div class="col-md-3"><label class="form-label" asp-for="Status">Estado</label><select class="form-select" asp-for="Status" asp-items="Html.GetEnumSelectList<DocumentStatus>()"></select></div>
            <div class="col-md-4"><label class="form-label" asp-for="PaymentMethod">Forma de pago</label><select class="form-select" asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select></div>
        </div>
        <datalist id="customers-list">
            @foreach (var customer in (IEnumerable<Customer>)ViewBag.CustomersData)
            {
                <option value="@customer.Name" data-id="@customer.Id"></option>
            }
        </datalist>
        <hr />
        <div class="row g-3 item-row">
            <div class="col-md-4"><label class="form-label">Producto / Servicio</label><select name="Items[0].ProductServiceId" class="form-select" asp-items="ViewBag.Products"></select></div>
            <div class="col-md-2"><label class="form-label">Cantidad</label><input name="Items[0].Quantity" class="form-control qty-input" value="1" /></div>
            <div class="col-md-3"><label class="form-label">Precio</label><input name="Items[0].UnitPrice" class="form-control price-input" value="0" /></div>
            <div class="col-md-3"><label class="form-label">Total</label><input name="Items[0].Total" class="form-control total-input" value="0" readonly /></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Guardar cotización</button>
            <a class="btn btn-outline-secondary" asp-action="Cotizaciones">Volver</a>
        </div>
    </form>
</section>
