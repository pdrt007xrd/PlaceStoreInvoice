@model IEnumerable<Quote>
@{
    ViewData["Title"] = "Cotizaciones";
}
<section class="panel-card">
    <div class="section-header">
        <h3 class="h5 mb-0">Cotizaciones</h3>
        <a class="btn btn-primary" asp-action="CrearCotizacion">Nueva cotizacion</a>
    </div>
    <table class="table table-striped datatable">
        <thead><tr><th>Numero</th><th>Fecha</th><th>Cliente</th><th>Estado</th><th>Total</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr><td>@item.Number</td><td>@item.Date.ToString("dd/MM/yyyy")</td><td>@item.Customer?.Name</td><td>@item.Status</td><td>@item.Total.ToString("N2")</td></tr>
        }
        </tbody>
    </table>
</section>
