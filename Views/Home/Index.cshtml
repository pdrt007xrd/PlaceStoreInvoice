@model Ventas.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-card">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <div class="small text-uppercase opacity-75">Resumen del dia</div>
            <h2 class="mt-2">Controla ventas, compras, tesoreria y reportes desde un solo panel.</h2>
            <p class="mb-0 opacity-75">Sesion protegida, datos centralizados y reportes listos para imprimir en PDF.</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <div class="h3 mb-0">@DateTime.Now.ToString("dd/MM/yyyy")</div>
            <div class="opacity-75">@DateTime.Now.ToString("hh:mm tt")</div>
        </div>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <div class="label">Clientes</div>
        <div class="value">@Model.Customers</div>
    </article>
    <article class="metric-card">
        <div class="label">Proveedores</div>
        <div class="value">@Model.Suppliers</div>
    </article>
    <article class="metric-card">
        <div class="label">Productos</div>
        <div class="value">@Model.Products</div>
    </article>
    <article class="metric-card">
        <div class="label">Cotizaciones hoy</div>
        <div class="value">@Model.QuotesToday</div>
    </article>
    <article class="metric-card">
        <div class="label">Facturas hoy</div>
        <div class="value">@Model.InvoicesToday</div>
    </article>
    <article class="metric-card">
        <div class="label">Ventas hoy</div>
        <div class="value">@Model.SalesToday.ToString("N2")</div>
    </article>
    <article class="metric-card">
        <div class="label">Compras hoy</div>
        <div class="value">@Model.PurchasesToday.ToString("N2")</div>
    </article>
    <article class="metric-card">
        <div class="label">Caja y bancos</div>
        <div class="value">@Model.CashBalance.ToString("N2")</div>
    </article>
</section>

<div class="row g-4">
    <div class="col-lg-7">
        <section class="panel-card">
            <div class="section-header">
                <h3 class="h5 mb-0">Accesos rapidos</h3>
            </div>
            <div class="quick-grid">
                <a class="quick-link" asp-controller="Ventas" asp-action="CrearFactura">
                    <strong>Nueva factura</strong>
                    <span>Registrar venta inmediata</span>
                </a>
                <a class="quick-link" asp-controller="Ventas" asp-action="CrearCotizacion">
                    <strong>Nueva cotizacion</strong>
                    <span>Preparar documento previo</span>
                </a>
                <a class="quick-link" asp-controller="Compras" asp-action="CrearRegistroCompra">
                    <strong>Nueva compra</strong>
                    <span>Registrar entrada pagada</span>
                </a>
                <a class="quick-link" asp-controller="Tesoreria" asp-action="CrearCobro">
                    <strong>Nuevo cobro</strong>
                    <span>Registrar ingreso de cliente</span>
                </a>
                <a class="quick-link" asp-controller="Reportes" asp-action="Ventas">
                    <strong>Reporte de ventas</strong>
                    <span>Filtrar y exportar PDF</span>
                </a>
                <a class="quick-link" asp-controller="Configuracion" asp-action="UsuariosRoles">
                    <strong>Usuarios y roles</strong>
                    <span>Administrar accesos</span>
                </a>
            </div>
        </section>
    </div>
    <div class="col-lg-5">
        <section class="panel-card">
            <div class="section-header">
                <h3 class="h5 mb-0">Alertas</h3>
            </div>
            <ul class="alert-list">
                @foreach (var alert in Model.Alerts)
                {
                    <li>@alert</li>
                }
            </ul>
        </section>
    </div>
</div>
